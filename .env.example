# Database
DATABASE_URL="file:./prisma/dev.db"

# Gemini AI (server-side only — never expose to frontend)
GEMINI_API_KEY=your_gemini_api_key_here

# Google OAuth (optional — auth is currently stubbed)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=

# Admin config
ADMIN_EMAIL=

# Cloudflare Pages deploy hook — paste your Pages project deploy hook URL here
# to enable the "Sync to Frontend" button in the admin dashboard.
# Get it from: Cloudflare Dashboard → Pages → Your Project → Settings → Builds & deployments → Deploy hooks
CLOUDFLARE_DEPLOY_HOOK=
